# ============================================================
# Team Memory 配置
# ------------------------------------------------------------
# 复制为 .env 并填入你的值。本工具走纯 Git 路线,
# 这些配置仅用于 sync 命令推送到 Gitea 远程仓库。
# 在拿到 Gitea 实例前, 可保留占位符先在本地跑通。
# ============================================================

# Gitea 远程仓库地址 —— 支持 SSH 或 HTTPS+token 两种:
#   SSH   : git@gitea.example.com:team/team-memory.git
#   HTTPS : https://gitea.example.com/team/team-memory.git
GITEA_REMOTE_URL=git@gitea.example.com:team/team-memory.git

# 仅当用 HTTPS + token 推送时需要; 用 SSH 方式可留空。
# 在 Gitea: 头像 -> 设置 -> 应用 -> 生成新的令牌(勾选 repo 权限)。
GITEA_TOKEN=

# 团队名 / 默认作者(写入记忆 frontmatter 的 author 字段)
TEAM_NAME=我们的团队
DEFAULT_AUTHOR=vayne

# 默认记忆仓库路径(init/sync/load/capture 不带 -p 时使用)
DEFAULT_MEMORY_PATH=./memory

# ============================================================
# 多源聚合(可选) —— 与现有 sync-remote-memory(tencent-openclaw)打通
# 留空则不聚合; 填路径后 load 可同时读取该源的记忆。
# ============================================================
TENCENT_OPENCLAW_PATH=
